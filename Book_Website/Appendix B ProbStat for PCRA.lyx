R_{y,\mathbf{x}}^{2} & =\mathrm{cor}\left(y,\hat{y}\right)^{2}\\
 & =\mathrm{cor}\left(y,\,\alpha\,+\,\mathrm{\mathbf{x}}^{\prime}\bubeta\right)^{2}\\
 & =\mathrm{cor}\left(y,\,\mathrm{\mathbf{x}}^{\prime}\bubeta\right)^{2}\\
 & =\frac{\mathrm{cov}\left(y,\,\mathrm{\mathbf{x}}^{\prime}\bubeta\right)^{2}}{\sigma_{y}^{2}\cdotp\mathrm{var}\left(\mathrm{\mathbf{x}}^{\prime}\bubeta\right)}\\
 & =\frac{\bubeta^{\prime}\busigma\busigma^{\prime}\bubeta}{\sigma_{y}^{2}\left(\bubeta^{\prime}\mathrm{\mathbf{C}}\bubeta\right)}\\
 & =\frac{\left(\busigma^{\prime}\mathrm{\mathbf{C}^{-1}}\busigma\right)^{2}}{\sigma_{y}^{2}\left(\busigma^{\prime}\mathrm{\mathbf{C}^{-1}}\busigma\right)}\\
