\begin_layout Subsection
mOpt Psi Function Formula 
\begin_inset CommandInset label
LatexCommand label
name "subsec: boundedRhoPsiFormula"

\end_inset


\end_layout

\begin_layout Standard
The mOpt psi function formula is
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
\psi_{mOpt}(x)=\begin{cases}
x & |x|\leqslant1\\
\dfrac{\phi(1)}{\phi(1)\,-\,a}\left(x\,-\,\mathrm{SGN}(x)\dfrac{a}{\phi(x)}\right)\mathrm{\mathit{U}}(c\,-\,|x|) & |x|>1
\end{cases}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
where 
\begin_inset Formula $\phi(x)$
\end_inset

 is the standard normal density function, 
\begin_inset Formula $\mathrm{\mathit{U}}(x)$
\end_inset

 is the unit step function whose value is 1 for 
\begin_inset Formula $x\geqslant0$
\end_inset

 and is 0 for 
\begin_inset Formula $x<0$
\end_inset

, and the constants 
\begin_inset Formula $a$
\end_inset

 and 
\begin_inset Formula $c$
\end_inset

 depend on the desired normal distribution efficiency.
 Note that 
\begin_inset Formula $\psi_{mOpt}(x)=0$
\end_inset

 for 
\begin_inset Formula $x$
\end_inset

 outside the interval 
\begin_inset Formula $(-c,\,c)$
\end_inset

.
 A 95% normal distribution efficiency is obtained with 
\begin_inset Formula $a=0.0132$
\end_inset

 and 
\begin_inset Formula $c=3.004$
\end_inset

.
 The rho function 
\begin_inset Formula $\rho_{mOpt}(x)$
\end_inset

 is obtained by an integration of 
\begin_inset Formula $\psi_{mOpt}(x)$
\end_inset

, and because the latter is zero outside the interval 
\begin_inset Formula $(-c,\,c)$
\end_inset

, the rho function is bounded with a constant value outside that interval.
 Details of the integral of the mOpt psi function, and computing values
 of 
\begin_inset Formula $a$
\end_inset

 and 
\begin_inset Formula $c$
\end_inset

 from specified normal distribution efficiencies are provided in 
\begin_inset CommandInset citation
LatexCommand citet
key "KonisMartin2021"
literal "false"

\end_inset

.
\end_layout

